{
  "manifest_version": 3,
  "name": "AI Page Summarizer",
  "short_name": "AI Summarizer",
  "version": "1.0.0",
  "description": "Extract readable webpage content, summarize it through a secure AI proxy, cache results per URL, and highlight key points.",
  "minimum_chrome_version": "109",
  "action": {
    "default_title": "AI Page Summarizer",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8787/*"
  ],
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
