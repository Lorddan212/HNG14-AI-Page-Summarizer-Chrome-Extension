# Local production-style AI proxy configuration.
# Copy this file to .env for local testing.
# Do not commit real secrets.

# Use one provider key depending on which proxy script you run.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

PORT=8787

# Optional comma-separated list. Example:
# ALLOWED_ORIGINS=chrome-extension://your-extension-id,http://localhost:8787
ALLOWED_ORIGINS=

# Optional in-memory rate limit controls.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=60
